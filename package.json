{
  "name": "@mweslley/mwcode",
  "version": "0.1.0",
  "description": "Sistema flexível de agentes de IA — modo Pessoal ou Empresa. 100% português brasileiro.",
  "type": "module",
  "bin": {
    "mwcode": "./bin/mwcode.js"
  },
  "files": [
    "bin",
    "install.sh",
    "cli",
    "server",
    "ui",
    "packages",
    "docker",
    "doc",
    ".env.example",
    "LICENSE",
    "README.md",
    "pnpm-workspace.yaml",
    "tsconfig.base.json",
    "drizzle.config.ts"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter @mwcode/server --filter @mwcode/ui dev",
    "dev:server": "pnpm --filter @mwcode/server dev",
    "dev:ui": "pnpm --filter @mwcode/ui dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @mwcode/server start",
    "db:generate": "pnpm --filter @mwcode/db generate",
    "db:migrate": "pnpm --filter @mwcode/db migrate",
    "db:push": "pnpm --filter @mwcode/db push",
    "mwcode": "tsx cli/index.ts",
    "postinstall": "node bin/mwcode.js version >/dev/null 2>&1 || true"
  },
  "keywords": [
    "ai",
    "agents",
    "chat",
    "cli",
    "openrouter",
    "openai",
    "gemini",
    "ollama",
    "portugues",
    "brasil"
  ],
  "author": "Michel Weslley <suporte@lojamwo.com.br>",
  "license": "MIT",
  "homepage": "https://github.com/mweslley/mwcode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mweslley/mwcode.git"
  },
  "bugs": {
    "url": "https://github.com/mweslley/mwcode/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  }
}
