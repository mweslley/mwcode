# Servidor
PORT=3100
MWCODE_MODE=flex

# Banco de dados (PostgreSQL)
# DATABASE_URL=postgres://user:pass@localhost:5432/mwcode

# Provedor padrão (modo Single)
MWCODE_PROVIDER=openrouter
MWCODE_MODEL=openrouter/auto

# Failover automático
MWCODE_FAILOVER=true
MWCODE_FAILOVER_ORDER=openrouter/openrouter/auto,ollama/qwen2.5-coder:7b

# Chaves de API
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GITHUB_TOKEN=

# Ollama local
OLLAMA_BASE_URL=http://localhost:11434
