# MWCode - Configuração
# Copie para .env e preencha suas chaves

# ============================================================
# CHAVES DE API (preencha pelo menos uma)
# ============================================================
# OPENROUTER (recomendado - tem modelos gratuitos)
# Pegue sua chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI (opcional)
#OPENAI_API_KEY=

# Gemini (opcional)
#GEMINI_API_KEY=

# DeepSeek (opcional)
#DEEPSEEK_API_KEY=

# ============================================================
# CONFIGURAÇÕES DO SERVIDOR
# ============================================================
PORT=3100
NODE_ENV=production

# Provedor padrão (openrouter, openai, gemini, deepseek, ollama)
MWCODE_PROVIDER=openrouter

# ============================================================
# FAILOVER (mudar de provedor automaticamente se um falhar)
# ============================================================
MWCODE_FAILOVER=true

# ============================================================
# UI (não precisa modificar)
# ============================================================
UI_PORT=5173
UI_PATH=./ui/dist