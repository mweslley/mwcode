# MWCode - Variáveis de Ambiente
# Copie este arquivo para .env e configure

# Provedor padrão (openrouter, openai, ollama, etc)
MWCODE_PROVIDER=openrouter

#Sua API Key do OpenRouter
# Pegue em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI (opcional)
#OPENAI_API_KEY=

# Ollama (opcional)
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=qwen2.5-coder:7b

# Configurações do servidor
PORT=3100
NODE_ENV=production

# Failover automático
MWCODE_FAILOVER=true